#include <iostream>
using namespace std;
int main() {
    long long n;
    if (cin >> n) {
        if (n == 0) {
            cout << "No Factors" << endl;
        } 
        else {
            if (n < 0) {
                n = -n;
            }
            for (long long i = 1; i <= n; i++) {
                if (n % i == 0) {
                    cout << i << " ";
                }
            }
            cout << endl;
        }
    }
    return 0;
}
