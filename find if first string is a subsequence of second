#include <iostream>
using namespace std;
int main() {
    char s1[100];
    char s2[100];
    cin >> s1 >> s2;
    int i = 0; 
    int j = 0; 
    while (s1[i] != '\0' && s2[j] != '\0') {
        if (s1[i] == s2[j]) {
            i++;
        }
        j++;
    }
    if (s1[i] == '\0') {
        cout << "True" << endl;
    } else {
        cout << "False" << endl;
    }
    return 0;
}
