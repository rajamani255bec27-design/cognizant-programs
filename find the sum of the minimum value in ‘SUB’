#include <iostream>
#include <vector>
#include <stack>
using namespace std;
long long sumSubarrayMins(vector<int>& ARR) {
    int n = ARR.size();
    vector<int> left(n), right(n);
    stack<int> s;
    for (int i = 0; i < n; i++) {
        while (!s.empty() && ARR[s.top()] >= ARR[i]) {
            s.pop();
        }
        left[i] = s.empty() ? i : i - s.top() - 1;
        s.push(i);
    }
    while (!s.empty()) s.pop();
    for (int i = n - 1; i >= 0; i--) {
        while (!s.empty() && ARR[s.top()] > ARR[i]) {
            s.pop();
        }
        right[i] = s.empty() ? n - i - 1 : s.top() - i - 1;
        s.push(i);
    }
    long long totalSum = 0;
    for (int i = 0; i < n; i++) {
        long long count = (long long)(left[i] + 1) * (right[i] + 1);
        totalSum += count * ARR[i];
    }
    return totalSum;
}
int main() {
    int n;
    if (cin >> n) {
        vector<int> ARR(n);
        for (int i = 0; i < n; i++) {
            cin >> ARR[i];
        }
        cout << sumSubarrayMins(ARR) << endl;
    }
    return 0;
}
