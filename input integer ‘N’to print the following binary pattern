#include <iostream>
using namespace std;
void printBinaryPattern(int n) {
    for (int i = 0; i < n; i++) {
        char bit;
        if (i % 2 == 0) {
            bit = '1';
        } else {
            bit = '0';
        }
        for (int j = 0; j < n - i; j++) {
            cout << bit;
        }
        cout << endl;
    }
}
int main() {
    int n;
    if (cin >> n) {
        printBinaryPattern(n);
    }
    return 0;
}
