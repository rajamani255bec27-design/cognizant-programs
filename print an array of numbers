#include <iostream>
using namespace std;
int main() {
    int n;
    cin >> n;
    int nums[100];
    int answer[100];
    for (int i = 0; i < n; i++) {
        cin >> nums[i];
    }
    int left_product = 1;
    for (int i = 0; i < n; i++) {
        answer[i] = left_product;
        left_product = left_product * nums[i];
    }
    int right_product = 1;
    for (int i = n - 1; i >= 0; i--) {
        answer[i] = answer[i] * right_product;
        right_product = right_product * nums[i];
    }

    for (int i = 0; i < n; i++) {
        cout << answer[i] << " ";
    }
    cout << endl;
    return 0;
}
