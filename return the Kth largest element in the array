#include <iostream>
using namespace std;
int main() {
    int nums[100]; 
    int count = 0;
    int val;
    while (cin >> val) {
        nums[count] = val;
        count++;
    }
    int k = nums[count - 1];
    int n = count - 1; 
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (nums[j] < nums[j + 1]) {
                int temp = nums[j];
                nums[j] = nums[j + 1];
                nums[j + 1] = temp;
            }
        }
    }
    cout << nums[k - 1] << endl;
    return 0;
}
